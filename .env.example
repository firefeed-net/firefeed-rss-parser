# FireFeed RSS Parser Environment Configuration

# API Connection - REQUIRED
FIREFEED_API_BASE_URL=http://firefeed-api:8000

# Service Token - REQUIRED for auth (paste generated token)
SERVICE_API_TOKEN=paste_your_rss-parser_token_here_from_tools_generate_service_token_py

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=firefeed_redis_pass
REDIS_DB=0

# Service ID
SERVICE_ID=rss-parser

# Logging
LOG_LEVEL=INFO

