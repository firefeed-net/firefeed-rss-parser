# FireFeed RSS Parser Environment Configuration
# Copy this file to .env and customize values as needed.
# Required for docker-compose.yml env_file.

# Service Configuration (moved from docker-compose.yml)
FIREFEED_SERVICE_ID=rss-parser
SERVICE_NAME=firefeed-rss-parser
SERVICE_VERSION=1.0.0

# API Authentication (required for API calls)
RSS_PARSER_TOKEN=your_rss_parser_token_here
# Alternative token name used in some services
FIREFEED_API_RSS_PARSER_TOKEN=your_rss_parser_token_here

# Logging Configuration (moved from docker-compose.yml)
LOG_LEVEL=INFO

# Feature Configuration (moved from docker-compose.yml)
TRANSLATION_ENABLED=true
DUPLICATE_DETECTION_ENABLED=true
CACHE_ENABLED=true

# Media Storage (moved from docker-compose.yml, matches volume)
IMAGES_ROOT_DIR=/app/data/images

# Processing Configuration (used in main.py, config.py)
MAX_CONCURRENT_FEEDS=10
FETCH_INTERVAL=600
FETCH_TIMEOUT=15.0
PARSER_TIMEOUT=10.0
MAX_RETRIES=3
RETRY_DELAY=1.0

# Redis Configuration (optional overrides, docker provides defaults)
# REDIS_PASSWORD=your_redis_password
# REDIS_SOCKET_TIMEOUT=5
# REDIS_SOCKET_CONNECT_TIMEOUT=5

# Other (used in tests/health)
# ENABLE_FALLBACK_FEEDS=false
# HEALTH_ENABLED=yes

# Notes:
# - Infra vars (FIREFEED_API_BASE_URL, REDIS_HOST/PORT/DB) are set in docker-compose.yml
# - Use `cp .env.example .env` to generate your local .env
# - docker-compose environment overrides .env values
