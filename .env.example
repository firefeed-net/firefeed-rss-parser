# FireFeed RSS Parser Environment Configuration

# Database Configuration
POSTGRES_PASSWORD=your_postgres_password_here

# API Configuration
FIREFEED_API_BASE_URL=http://localhost:8001
FIREFEED_API_TOKEN=your_firefeed_api_token_here
FIREFEED_SERVICE_ID=rss-parser

# Service Configuration
SERVICE_NAME=rss-parser
LOG_LEVEL=INFO
MAX_CONCURRENT_FEEDS=10
FETCH_TIMEOUT=30
PARSER_TIMEOUT=10
MAX_RETRIES=3
RETRY_DELAY=1.0

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# Translation Configuration
TRANSLATION_ENABLED=true
TRANSLATION_MODEL=facebook/m2m100_418M
TRANSLATION_MAX_CONCURRENT=3
TRANSLATION_DEVICE=cpu

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=10000

# Duplicate Detection
DUPLICATE_DETECTION_ENABLED=true
DUPLICATE_DETECTOR_MODEL=paraphrase-multilingual-MiniLM-L12-v2
DUPLICATE_SIMILARITY_THRESHOLD=0.9

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=8080
METRICS_PATH=/metrics
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_PORT=8081
HEALTH_CHECK_PATH=/health

# Security
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Paths
HTTP_IMAGES_ROOT_DIR=/app/data/images
IMAGES_ROOT_DIR=/app/data/images
VIDEOS_ROOT_DIR=/app/data/videos
HTTP_VIDEOS_ROOT_DIR=/app/data/videos

# Cleanup
RSS_PARSER_CLEANUP_INTERVAL_HOURS=0

# User Agent
DEFAULT_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36 FireFeed/1.0
RSS_PARSER_TOKEN=your_rss_parser_token_here

# Environment
ENVIRONMENT=development
